# Auto detect text files and normalize to LF
*          text=auto eol=lf

# Source code
*.vue      text eol=lf
*.ts       text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.tsx      text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.less     text eol=lf
*.html     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.xml      text eol=lf
*.svg      text eol=lf

# Config files
*.config.* text eol=lf
*.rc       text eol=lf
.env*      text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf

# Shell scripts
*.sh       text eol=lf

# Windows scripts (keep CRLF as required by Windows)
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary files (no normalization)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
*.mp3      binary
*.mp4      binary
*.zip      binary
*.gz       binary
